#!/usr/bin/env bash

static_projects=(
    "$HOME/.config/nvim"
    "$HOME/notes"
    "run"
    "ssh-tunnel"
)

dynamic_projects=$(
    find \
        ~/indicium \
        ~/.config/nvim \
        \( \
            -name '.git'          \
            -o -name 'node_modules' \
            -o -name 'target'     \
            -o -name 'vendor'     \
            -o -name 'dist'       \
            -o -name 'build'      \
            -o -name '.next'      \
            -o -name '.nuxt'      \
            -o -name '.venv'      \
            -o -name 'venv'       \
            -o -name 'env'        \
            -o -name '__pycache__' \
            -o -name '.mypy_cache' \
            -o -name '.pytest_cache' \
            -o -name '.ruff_cache' \
            -o -name '.ruff_cache' \
        \) -prune \
        -o -type d -exec sh -c '
            for marker in \
                .git         \
                go.mod       \
                Cargo.toml   \
                package.json \
                pyproject.toml \
                setup.py     \
                Pipfile      \
            ; do
                [ -e "$1/$marker" ] && exit 0
            done
            exit 1
        ' _ {} \; -print -prune
)

selected=$(printf "%s\n" "${static_projects[@]}" $dynamic_projects | fzf)

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(echo "$selected" | tr . _ | tr / - | sed 's/.*\(.\{64\}\)/\1/')
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s $selected_name -c $selected
    exit 0
fi

if ! tmux has-session -t=$selected_name 2>/dev/null; then
    tmux new-session -ds $selected_name -c $selected
fi

tmux switch-client -t $selected_name
